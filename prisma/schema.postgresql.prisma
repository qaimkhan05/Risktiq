generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  role                String               @default("USER")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  profile             TradingProfile?
  trades              Trade[]
  goals               Goal[]
  reflections         DailyReflection[]
  passwordResetTokens PasswordResetToken[]
}

model TradingProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  fullName            String
  tradingStyle        String
  dailyTradeLimit     Int
  weeklyTradeLimit    Int
  monthlyProfitTarget Float
  monthlyLossLimit    Float
  preferredStrategies String   @default("[]")
  riskPerTrade        Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trade {
  id                  String   @id @default(cuid())
  userId              String
  tradeDate           DateTime
  assetName           String
  direction           String
  quantity            Float
  entryPrice          Float
  exitPrice           Float
  stopLoss            Float
  takeProfit          Float
  pnlAmount           Float
  riskRewardRatio     Float
  strategyUsed        String
  screenshotUrl       String?
  emotionalBefore     String
  emotionalAfter      String
  mistakeMade         String?
  lessonsLearned      String?
  tradeNotes          String?
  outcome             String
  overtradingFlag     Boolean  @default(false)
  revengeTradingFlag  Boolean  @default(false)
  emotionalWarning    Boolean  @default(false)
  consecutiveLossFlag Boolean  @default(false)
  ruleBreakCount      Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tradeDate])
  @@index([userId, strategyUsed])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  targetValue  Float
  currentValue Float    @default(0)
  status       String   @default("ACTIVE")
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model DailyReflection {
  id               String   @id @default(cuid())
  userId           String
  reflectionDate   DateTime
  wins             String
  challenges       String
  disciplineScore  Int
  psychologyScore  Int
  performanceScore Int
  gratitude        String?
  tomorrowFocus    String?
  journalCompleted Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reflectionDate])
  @@index([userId, reflectionDate])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
